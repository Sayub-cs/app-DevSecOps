pipeline {
    agent { label 'agent-master' }

    options {
        skipDefaultCheckout(true)
    }

    environment {
        SERVICE_NAME    = 'user-service'
        SERVICE_DIR     = 'user-service'
   
        GIT_REPO        = 'http://github.com/Sayub-cs/app-DevSecOps'
        GIT_BRANCH      = 'main'

        DockerHub_REGISTRY = 'sayubb'
        DockerHub_repo  = 'app-angular-springing-user-service'
        IMAGE_NAME      = "${DockerHub_REGISTRY}/${DockerHub_repo}"
        IMAGE_TAG       = "${BUILD_NUMBER}"

        //GITLAB_HOST     = 'gitlab.local'
        //K8S_BRANCH      = 'master'
        DEPLOYMENT_FILE = 'user-service/deployment.yaml'
    }

    stages {

        stage('Checkout Backend Repo') {
            steps {
                git branch: "${GIT_BRANCH}",
                    credentialsId: 'github-creds',
                    url: "${GIT_REPO}"
            }
        }

        stage('Verify Project') {
            steps {
                sh """
                    echo "==> Current workspace"
                    pwd
                    ls -la

                    echo "==> Verify user-service files"
                    test -d ${SERVICE_DIR}
                    test -f ${SERVICE_DIR}/Dockerfile
                    test -f ${SERVICE_DIR}/pom.xml
                    test -d ${SERVICE_DIR}/src

                    echo "==> user-service structure"
                    ls -la ${SERVICE_DIR}
                """
            }
        }

        stage('Verify Docker Access') {
            steps {
                sh """
                    docker --version
                    docker ps
                """
            }
        }

        stage('Clean Docker') {
            steps {
                sh 'docker system prune -a -f || true'
                sh 'docker builder prune -a -f || true'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                    docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ${SERVICE_DIR}
                    docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest
                """
            }
        }

        stage('Login to DockerHub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKERHUB_USER',
                    passwordVariable: 'DOCKERHUB_PASS'
                )]) {
                    sh '''
                        echo "${DOCKERHUB_PASS}" | docker login ${DockerHub_REGISTRY} -u "${DOCKERHUB_USER}" --password-stdin
                    '''
                }
            }
        }

        stage('Push Image to DockerHub') {
            steps {
                sh '''
                    docker push ${IMAGE_NAME}:${IMAGE_TAG}
                    docker push ${IMAGE_NAME}:latest
                '''
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh """
                    echo "==> Deploying user-service to Kubernetes"
                    kubectl apply -f ${DEPLOYMENT_FILE} --record
                """
            }
        }
    }

    post {
        always {
            sh '''
                docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true
                docker rmi ${IMAGE_NAME}:latest || true
                docker logout ${DockerHub_REGISTRY} || true
            '''
        }

        success {
            echo "user-service image pushed successfully: ${IMAGE_NAME}:${IMAGE_TAG}"
        }

        failure {
            echo "user-service pipeline failed. Check Jenkins logs."
        }
    }
}